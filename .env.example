# Contact form — Resend email delivery
# Copy this file to .env.local and fill in real values.

# Resend API key (https://resend.com/api-keys). Server-only — never exposed to the client.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form inquiries.
CONTACT_EMAIL=you@example.com

# Optional: verified sender. Defaults to Resend's shared onboarding@resend.dev
# (fine for testing). For production, verify your own domain in Resend and set
# something like: Akxost Studio <hello@yourdomain.com>
# CONTACT_FROM=Akxost Studio <onboarding@resend.dev>
